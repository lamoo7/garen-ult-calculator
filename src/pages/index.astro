---
import BackgroundLayers from "../components/BackgroundLayers.astro";
import IconToggle from "../components/IconToggle.astro";
import SkinCircle from "../components/SkinCircle.astro";
import Layout from "../layouts/Layout.astro";
import {
	ENEMY_HEALTH,
	MODIFIERS,
	ULT_ICON,
	ULT_RANKS,
	modifierEffect,
	rankEffect,
} from "../data/loadout";
import { SKINS } from "../data/skins";
---

<Layout>
	<BackgroundLayers />

	<main>
		<div class="inputs">
			<section class="step">
				<h2><span class="num">1</span>Ultimate Rank</h2>
				<div class="row">
					{
						ULT_RANKS.map((rank) => (
							<IconToggle
								variant="rank"
								id={`rank${rank.rank}`}
								group="ultRank"
								value={String(rank.rank)}
								checked={rank.rank === 1}
								image={ULT_ICON}
								alt={`rank ${rank.rank}`}
								badge={String(rank.rank)}
								pips={rank.pips}
								caption={rankEffect(rank)[0]}
								effect={rankEffect(rank)[1]}
							/>
						))
					}
				</div>
			</section>

			<section class="step">
				<h2><span class="num">2</span>Items &amp; Runes</h2>
				<div class="row items">
					{
						MODIFIERS.map((modifier) => (
							<IconToggle
								id={modifier.id}
								image={modifier.image}
								alt={modifier.name}
								caption={modifier.short}
								effect={modifierEffect(modifier)}
							/>
						))
					}
				</div>
			</section>

			<section class="step">
				<h2><span class="num">3</span>Enemy Max HP</h2>
				<div class="row">
					<input
						type="number"
						id="health"
						placeholder="enemy HP"
						min={ENEMY_HEALTH.min}
						max={ENEMY_HEALTH.max}
					/>
				</div>
			</section>
		</div>

		<aside id="readout">
			<p class="readout-label">Execute below</p>
			<p class="readout-value"><span id="result">0 HP</span></p>
			<p id="previously" hidden>
				was <span id="result-previous">0 HP</span>
			</p>

			<div
				class="hp-bar"
				role="progressbar"
				aria-label="Execute threshold as a share of enemy max health"
				aria-valuemin="0"
				aria-valuenow="0"
				aria-valuemax="0"
			>
				<div class="hp-fill"></div>
			</div>
			<p class="scale">
				<span>0</span>
				<span id="hp-max">&mdash;</span>
			</p>
		</aside>
	</main>

	<div id="background-change">
		{SKINS.map((skin) => <SkinCircle skin={skin} />)}
	</div>
</Layout>

<script>
	import "../scripts/main";
</script>

<style>
	/* ===== LAYOUT CONTAINERS ===== */
	main,
	#background-change {
		width: min(90%, var(--max-width));
		margin-inline: auto;
		padding: clamp(1rem, 3vw, 1.5rem);
		border-radius: 1rem;
		background: rgba(0, 0, 0, 0.35);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}

	/* Inputs on the left, the answer on the right — so the number you came for is
	   in view the whole time you're toggling, instead of below the fold. */
	main {
		margin-block: clamp(0.5rem, 2vw, 1rem);
		display: grid;
		gap: clamp(1rem, 3vw, 2rem);
		align-items: start;
	}

	/* The skin picker is its own row of circles — no inner wrapper needed. */
	#background-change {
		margin-block: clamp(0.5rem, 2vw, 1rem) clamp(1rem, 3vw, 2rem);
		padding: clamp(0.75rem, 2vw, 1rem);
		display: flex;
		justify-content: center;
		align-items: center;
		gap: clamp(0.5rem, 2vw, 1rem);
		flex-wrap: wrap;
	}

	/* ===== STEPS ===== */
	.inputs {
		display: grid;
		gap: clamp(1.25rem, 3vw, 1.75rem);
	}

	.step {
		display: grid;
		gap: var(--space-sm);
	}

	.step + .step {
		padding-top: clamp(1.25rem, 3vw, 1.75rem);
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	/* One numbered row per step, all three identical — the old page put 1 and 2
	   side by side and stranded 3 underneath, so there was no reading order. */
	.step h2 {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.85);
	}

	/* Centring a digit in a circle takes more than place-items. The heading's
	   letter-spacing is inherited and lands *after* the digit, so centring the
	   advance pushed the glyph a pixel left; the glyph's leading dropped it below
	   the middle; and the text-shadow dragged its visual weight down. */
	.num {
		display: grid;
		place-items: center;
		width: 1.5rem;
		height: 1.5rem;
		flex: none;
		border-radius: 50%;
		background: var(--color-primary);
		color: #fff;
		font-size: 0.8rem;
		font-weight: 800;
		line-height: 1;
		letter-spacing: normal;
		font-variant-numeric: tabular-nums;
	}

	/* Indented to start under the heading text rather than the number chip, so the
	   three steps share one left edge instead of floating centred. */
	.row {
		display: flex;
		align-items: flex-start;
		gap: var(--space-sm);
		flex-wrap: wrap;
		padding-inline-start: calc(1.5rem + var(--space-sm));
	}

	/* ===== READOUT ===== */
	#readout {
		display: grid;
		justify-items: center;
		gap: var(--space-xs);
		padding: clamp(1rem, 3vw, 1.5rem);
		border-radius: 0.75rem;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(0, 0, 0, 0.45);
	}

	.readout-label {
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.7);
	}

	.readout-value {
		font-size: clamp(2rem, 7vw, 3rem);
		line-height: 1.1;
	}

	#result {
		color: #ff4444;
		font-weight: 900;
		white-space: nowrap;
	}

	/* The old threshold, deliberately quieter than the live one. Neutral on purpose —
	   it reads the same whether the ult was nerfed or buffed. */
	#previously {
		font-size: var(--font-size-sm);
		color: rgba(255, 255, 255, 0.6);
	}

	#result-previous {
		color: rgba(255, 255, 255, 0.85);
		font-weight: 700;
		white-space: nowrap;
	}

	/* Endpoints, so the bar says what fraction of the enemy's health it represents.
	   Must track the bar's width exactly or the labels stop lining up with its ends. */
	.scale {
		display: flex;
		justify-content: space-between;
		width: min(100%, 10rem);
		margin-top: 2px;
		font-size: 0.7rem;
		font-variant-numeric: tabular-nums;
		color: rgba(255, 255, 255, 0.55);
	}

	/* ===== ENEMY HEALTH INPUT ===== */
	input[type="number"] {
		width: min(22ch, 90vw);
		max-width: 100%;
		padding: 0.75rem 1rem;
		font-size: clamp(1.25rem, 4vw, 1.5rem);
		font-weight: 700;
		color: var(--color-primary);
		border: 2px solid transparent;
		border-radius: var(--space-sm);
		background: var(--color-background);
		text-align: center;
		transition: border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
		-moz-appearance: textfield;
	}

	input[type="number"]:focus {
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
		outline: none;
	}

	input[type="number"]::-webkit-inner-spin-button,
	input[type="number"]::-webkit-outer-spin-button {
		-webkit-appearance: none;
		margin: 0;
	}

	/* ===== EXECUTE THRESHOLD BAR =====
	   Built to read as an in-game enemy health bar: black frame, near-black empty
	   track, glossy red fill, and the 100-HP tick marks. It's a div rather than a
	   <progress> because the fill pseudo-element of a <progress> paints over the
	   track, which buries any ticks drawn underneath it.

	   Width is capped against the panel, not a fixed 320px — that ignored how wide
	   the readout actually is and hung ~50px out the side of it on desktop. */
	.hp-bar {
		position: relative;
		/* Roughly the 12:1 of an in-game champion bar. Wider than this and it stops
		   reading as a health bar and starts reading as a progress meter. */
		width: min(100%, 10rem);
		height: 13px;
		margin-top: var(--space-sm);
		border: 1px solid #05060a;
		border-radius: 2px;
		overflow: hidden;
		background: linear-gradient(to bottom, #202227, #0d0e11);
		box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.9),
			0 0 0 1px rgba(190, 200, 215, 0.25);
	}

	.hp-fill {
		width: 0;
		height: 100%;
		background: linear-gradient(
			to bottom,
			#e8635a 0%,
			#d1332a 38%,
			#a11d16 62%,
			#5f130f 100%
		);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
		transition: width var(--transition);
	}

	/* Two tick scales, as in game: a minor tick every 100 HP that hangs half-way down
	   from the top, and a bolder, full-height major tick every 1000. Both are one
	   layer of ::after — the major is listed first so it paints over the minor tick
	   that lands on the same 1000-HP boundary. background-size clips the minor layer
	   to the top half; the major spans the full height.

	   The two --tick-* vars are the segment widths as percentages, set by the
	   calculator, which widens the minor step when 100 HP would pack the ticks
	   closer than they can be drawn and they'd smear into a solid block. */
	.hp-bar::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image: repeating-linear-gradient(
				to right,
				transparent 0,
				transparent calc(var(--tick-major, 100%) - 2px),
				rgba(0, 0, 0, 0.85) calc(var(--tick-major, 100%) - 2px),
				rgba(0, 0, 0, 0.85) var(--tick-major, 100%)
			),
			repeating-linear-gradient(
				to right,
				transparent 0,
				transparent calc(var(--tick-minor, 100%) - 1px),
				rgba(0, 0, 0, 0.55) calc(var(--tick-minor, 100%) - 1px),
				rgba(0, 0, 0, 0.55) var(--tick-minor, 100%)
			);
		background-size: 100% 100%, 100% 50%;
		background-position: 0 0, 0 0;
		background-repeat: no-repeat, no-repeat;
	}

	/* ===== RESPONSIVE ===== */
	@media (min-width: 768px) {
		main {
			grid-template-columns: 1fr minmax(240px, 20rem);
		}

		/* Follows the steps down the page as you scroll a long loadout. */
		#readout {
			position: sticky;
			top: var(--space-md);
		}
	}

	@media (min-width: 1024px) {
		main,
		#background-change {
			width: min(85%, var(--max-width));
		}
	}

	/* No room for a side column on a phone, so the answer docks to the bottom of the
	   screen instead — it stays visible while you work down the steps above it. */
	@media (max-width: 767px) {
		#readout {
			position: sticky;
			bottom: var(--space-sm);
			/* Opaque, not glassy: while docked it floats over step 3, and even at 6%
			   transparency the white HP input showed through behind the number. */
			background: #0f0f12;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
		}
	}

	@media (max-width: 480px) {
		/* Six icons don't quite fit one phone row and wrapped to a lone orphan on
		   the second. Three-up gives the ranks one tidy row and the items two. */
		.items {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			justify-items: center;
			gap: var(--space-md) var(--space-sm);
			padding-inline-start: 0;
		}
	}
</style>
